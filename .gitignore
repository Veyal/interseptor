# OS / editor cruft
.DS_Store
*.swp

# Personal, per-user Claude Code overrides
.claude/settings.local.json

# Compiled binary
/interceptor
/interceptor.exe
*.exe
*.exe~

# Local dev logs / preview config
/_dev.log
/_*.log
/.claude/launch.json

# Local runtime data (created under ~/.interceptor by default; ignore if run in-tree)
/.interceptor/

# CI/release workflows are staged locally but not committed yet — pushing
# .github/workflows/* needs a git token with the `workflow` scope. Re-enable
# with: git add -f .github/workflows && git commit && git push
/.github/
